{
  "name": "teste-colmeia-qa",
  "version": "1.0.0",
  "description": "Projeto de automação de testes",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "npx cypress open --config-file config-avaliacao-qa.js",
    "cy:open:dev": "npx cypress open --config-file config-avaliacao-dev.js --browser chrome",
    "cy:open:qa": "npx cypress open --config-file config-avaliacao-qa.js --browser chrome",
    "cy:run:qa": "npx cypress run --config-file config-avaliacao-qa.js --browser chrome",
    "cy:run:qaReport": "npx cypress run --config-file config-avaliacao-qa.js --browser chrome && npm run report",
    "cy:run:qa:headed": "npx cypress run --config-file config-avaliacao-qa.js --browser chrome --headed",
    "merge-reports": "npx mochawesome-merge cypress/reports/.jsons/*.json > cypress/reports/report.json",
    "generate-report": "npx marge cypress/reports/report.json --reportDir cypress/reports --reportFilename index --inline",
    "report": "npm run merge-reports && npm run generate-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cypress": "^15.14.2",
    "cypress-mochawesome-reporter": "^4.0.2",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "dotenv": "^17.4.2"
  }
}
